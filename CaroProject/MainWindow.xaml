<Window
    x:Class="CaroProject.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock x:Name="TurnText" Text="Luot di: Nguoi choi 1 (X)" FontSize="24" Margin="0,0,0,20" Foreground="Black" FontWeight="Bold"/>

            <Border BorderBrush="Black" BorderThickness="2">
                <Grid x:Name="BoardGrid" Background="LightGray">
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Spacing="20">
                <Button Content="Goi Y Nuoc Di" Width="150" Height="40" Click="HintButton_Click"/>
                <Button Content="Choi Lai" Width="120" Height="40" Click="RestartButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>